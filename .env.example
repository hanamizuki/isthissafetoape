# Frontend (Vite) — copy to .env and fill in
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# Edge function secrets are NOT loaded from this file.
# Set them with `supabase secrets set` — see README for the full list.
